true_col <- pair[2]
# Check if columns exist and are not empty
if (!estimated_col %in% colnames(data)) {
warning(paste("Missing column:", estimated_col))
next
}
if (!true_col %in% colnames(data)) {
warning(paste("Missing column:", true_col))
next
}
if (all(is.na(data[[estimated_col]]))) {
warning(paste("No data in column:", estimated_col))
next
}
if (all(is.na(data[[true_col]]))) {
warning(paste("No data in column:", true_col))
next
}
# Calculate the 95% credible interval
lower_bound <- quantile(data[[estimated_col]], probs = 0.025, na.rm = TRUE)
upper_bound <- quantile(data[[estimated_col]], probs = 0.975, na.rm = TRUE)
# Convert true value
true_value <- unique(data[[true_col]]) * conversion_factor
# Check if the true value is within the interval
in_ci <- lower_bound <= true_value & true_value <= upper_bound
# Add to results
results <- rbind(results, data.frame(Population_Pair = estimated_col,
Lower_Bound = lower_bound,
Upper_Bound = upper_bound,
True_Value = true_value,
In_CI = in_ci))
}
# Print results
print(results)
# Proportion of population pairs where true value is in CI
p_in_CI <- mean(results$In_CI)
print(paste("Proportion of true values in CI:", p_in_CI))
